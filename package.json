{
  "name": "payment-gateway-backend",
  "version": "1.0.0",
  "description": "Payment Gateway Backend - NestJS",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json || true && echo \"require('reflect-metadata'); require('./main.js');\" > dist/app.js",
    "start": "node app.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:prod": "node app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate || true"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": { "^@/(.*)$": "<rootDir>/$1" }
  },
  "dependencies": {
    "@nestjs/common": "10.4.2",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.2",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.2",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/throttler": "6.3.0",
    "@prisma/client": "5.22.0",
    "@types/node": "20.17.0",
    "axios": "1.7.9",
    "bcryptjs": "2.4.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "compression": "1.7.4",
    "helmet": "8.0.0",
    "mercadopago": "2.0.15",
    "nodemailer": "6.9.16",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "prisma": "5.22.0",
    "qrcode": "1.5.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.6.3",
    "uuid": "9.0.1"
  },
  "overrides": {
    "multer": "^2.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.2",
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.7.5",
    "@types/jest": "29.5.14",
    "@types/nodemailer": "6.4.17",
    "@types/passport-jwt": "4.0.1",
    "@types/qrcode": "1.5.5",
    "@types/uuid": "9.0.8",
    "jest": "29.7.0",
    "ts-jest": "29.2.5"
  }
}
