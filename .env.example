# ============================================================
# RAZEPAGUE - CONFIGURAÇÕES DO SISTEMA
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- DATABASE (MySQL/MariaDB - Hostinger VPS) ---
MYSQL_DATABASE=razepag
MYSQL_USER=razepaguser
MYSQL_PASSWORD=SUA_SENHA_AQUI
MYSQL_ROOT_PASSWORD=SUA_SENHA_ROOT_AQUI
DATABASE_URL="mysql://razepaguser:SUA_SENHA_AQUI@mysql:3306/razepag"

# --- REDIS ---
REDIS_PASSWORD=SUA_SENHA_REDIS
REDIS_URL=redis://:SUA_SENHA_REDIS@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (OBRIGATÓRIO: use strings longas e aleatórias) ---
JWT_SECRET=gere_uma_string_aleatoria_de_64_chars_aqui
JWT_REFRESH_SECRET=gere_outra_string_aleatoria_de_64_chars_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- APP ---
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://seudominio.com
NEXT_PUBLIC_API_URL=http://backend:3001
BASE_URL=https://seudominio.com

# --- MERCADO PAGO ---
MERCADO_PAGO_ACCESS_TOKEN=seu_access_token_mp
MERCADO_PAGO_PUBLIC_KEY=sua_public_key_mp

# --- TAXAS ---
PIX_FEE_PERCENTAGE=3
PIX_FEE_FLAT=1.00
TRANSFER_FEE_FLAT=0
WITHDRAWAL_FEE_PERCENTAGE=2.0
MIN_WITHDRAWAL_AMOUNT=10

# --- ADMIN (criado automaticamente no primeiro seed) ---
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=SenhaAdminSegura@2025
ADMIN_NAME=Super Admin

# --- SECURITY ---
WEBHOOK_SECRET=gere_uma_string_aleatoria_de_32_chars
ENCRYPTION_KEY=gere_uma_string_hex_de_32_bytes

# --- EMAIL SMTP (Hostinger, Gmail, SendGrid etc.) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com
SMTP_PASS=sua_senha_smtp
SMTP_FROM=noreply@seudominio.com
