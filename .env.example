# ============================================================
# RAZEPAGUE - CONFIGURAÇÕES DO SERVIDOR (backend)
# No Hostinger: cole cada variável em Node.js → Environment Variables
# ============================================================

# --- DATABASE (MySQL - Hostinger) ---
DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/NOME_DO_BANCO"

# --- JWT (gere strings longas e aleatórias) ---
JWT_SECRET=gere_uma_string_aleatoria_de_64_chars_aqui
JWT_REFRESH_SECRET=gere_outra_string_aleatoria_de_64_chars_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- APP ---
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://seudominio.com
BASE_URL=https://seudominio.com

# --- MERCADO PAGO ---
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-922464385834428-040920-474034e7bd10f71288c433865079f711-3318003123
MERCADO_PAGO_PUBLIC_KEY=sua_public_key_mp

# --- TAXAS PIX ---
PIX_FEE_PERCENTAGE=3
PIX_FEE_FLAT=1.00
TRANSFER_FEE_FLAT=0
WITHDRAWAL_FEE_PERCENTAGE=2.0
MIN_WITHDRAWAL_AMOUNT=10

# --- ADMIN (criado no primeiro seed) ---
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=SenhaAdminSegura@2025
ADMIN_NAME=Super Admin

# --- SECURITY ---
WEBHOOK_SECRET=gere_uma_string_aleatoria_de_32_chars
ENCRYPTION_KEY=gere_uma_string_hex_de_32_bytes

# --- EMAIL SMTP ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com
SMTP_PASS=sua_senha_smtp
SMTP_FROM=noreply@seudominio.com
